@inject IJSRuntime JS

<canvas @ref="_canvas" class="hero__canvas" aria-hidden="true"></canvas>

@code {
    private ElementReference _canvas;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { await JS.InvokeVoidAsync("portfolio.initHero", _canvas); }
            catch { /* reduced motion / JS unavailable */ }
        }
    }
}
