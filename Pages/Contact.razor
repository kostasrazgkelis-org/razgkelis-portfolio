@page "/contact"

<PageTitle>Contact — Konstantinos A. Razgkelis</PageTitle>

<section class="section" style="padding-top:calc(var(--nav-h) + 5rem);min-height:80svh;display:flex;align-items:center">
    <div class="container contact-cta" data-reveal>
        <span class="eyebrow" style="justify-content:center">Get in touch</span>
        <h2 style="margin-top:1rem">Let's build<br />something.</h2>
        <p class="lead" style="margin:1.4rem auto 0;max-width:520px">
            Open to backend, mobile and platform work, collaborations and good conversations.
            The fastest way to reach me is email.
        </p>

        <a class="contact-mail" href="mailto:@Site.Email">@Site.Email</a>

        <div class="hero__cta" style="justify-content:center;margin-top:1rem">
            <a class="btn btn--primary" href="mailto:@Site.Email">Email me</a>
            <a class="btn btn--ghost" href="@Site.CvPath" download>Download CV</a>
        </div>

        <div style="display:flex;justify-content:center;margin-top:2.4rem">
            <SocialLinks />
        </div>
    </div>
</section>
